  <svg
    id="dr-mark"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 350 510"
    fill="none"
    aria-hidden="true"
  >
    <g id="dr-edges">
      <polyline data-b="6" points="283,30 325,52"></polyline>
      <polyline data-b="6" points="283,30 243,52"></polyline>
      <polyline data-b="6" points="243,52 285,74"></polyline>
      <polyline data-b="6" points="325,52 285,74"></polyline>
      <polyline data-b="5" points="325,230 325,52"></polyline>
      <polyline data-b="5" points="287,230 285,74"></polyline>
      <polyline data-b="5" points="243,155 243,52"></polyline>
      <polyline data-b="4" points="170,113 243,155"></polyline>
      <polyline data-b="4" points="170,113 12,204"></polyline>
      <polyline data-b="3" points="12,204 50,230"></polyline>
      <polyline data-b="4" points="50,230 170,163"></polyline>
      <polyline data-b="4" points="243,205 170,163"></polyline>
      <polyline data-b="4" points="243,205 243,155"></polyline>
      <polyline data-b="1" points="325,408 325,230"></polyline>
      <polyline data-b="1" points="287,371 287,230"></polyline>
