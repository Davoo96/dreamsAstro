      ></polyline>
      <polyline data-b="0" points="12,405 170,497"></polyline>
      <polyline data-b="0" points="170,497 325,408"></polyline>
      <polyline data-b="0" points="50,370 170,439 287,371"></polyline>
      <polyline data-b="0" points="170,497 170,439"></polyline>
      <polyline data-b="0" points="105,348 50,370"></polyline>
      <polyline data-b="0" points="238,348 287,371"></polyline>
    </g>
  </svg>

  <div id="dr-text">
    <span id="dr-word">DREAMS</span>
    <span id="dr-sub">INCORPORADORA</span>
  </div>
</div>

<style is:global>
  @font-face {
    font-family: "Aspire Font";
    src: url("/fonts/Aspire-Font.ttf") format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #dr-pre {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: radial-gradient(
      ellipse at center,
      #2a2d30 0%,
      #1f2224 55%,
      #121416 100%
    );
    opacity: 1;
    transition: opacity 800ms ease;
    pointer-events: none;
  }

  #dr-lock {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9999;
    transform-origin: top left;
    display: flex;
    align-items: center;
    gap: 16px;
    pointer-events: none;
    visibility: hidden;
  }

  body.dreams-intro-active #dr-lock {
    visibility: visible;
    will-change: transform, opacity;
  }

  #dr-mark {
    flex-shrink: 0;
    height: 94px;
    width: auto;
  }

  #dr-mark polyline {
    fill: none;
    stroke: #fc4c02;
    stroke-width: 6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #dr-text {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }

  #dr-sub {
    opacity: 0;
    transition: opacity 500ms ease 150ms;
    color: #ffffff;
    font-family: "Poppins", sans-serif;
    font-size: clamp(0.75rem, 2.4vw, 1rem);
    font-weight: 200;
    line-height: 1;
    letter-spacing: 0;
    white-space: nowrap;
  }

  #dr-word {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 600ms ease,
      transform 600ms ease;
    color: #ffffff;
    font-family: "Aspire Font", sans-serif;
    font-size: clamp(2.25rem, 7vw, 4rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #dr-word.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #dr-sub.is-visible {
    opacity: 1;
  }

  body.dreams-intro-active {
    overflow: hidden;
    background: #1f2224;
  }

  html:has(body.dreams-intro-active),
  html:has(body.dreams-intro-pending) {
    background: #1f2224;
  }

  body.dreams-intro-pending {
    background: #1f2224;
  }

  body.dreams-intro-pending > :not(#dr-pre):not(#dr-lock) {
    opacity: 0;
    pointer-events: none;
  }

  body.dreams-intro-revealed > nav [data-nav-item] {
    opacity: 1;
    transition: opacity 500ms ease;
  }

  body:not(.dreams-intro-pending) > nav [data-nav-item] {
    opacity: 1;
  }

  body.dreams-intro-pending > nav [data-nav-item] {
    opacity: 0;
  }

  html.dreams-intro-skip #dr-pre,
  html.dreams-intro-skip #dr-lock {
    display: none !important;
  }

  html.dreams-intro-skip
    body.dreams-intro-pending
    > :not(#dr-pre):not(#dr-lock) {
    opacity: 1;
    pointer-events: auto;
  }

  html.dreams-intro-skip #nav-logo-static {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }
</style>
